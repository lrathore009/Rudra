# Rudra frontend environment (Next.js)
# Copy to .env.local for local development:  cp .env.example .env.local
#
# Next.js reads env files from THIS directory (frontend/), not the repo root.
# Variables must be prefixed NEXT_PUBLIC_ to be exposed to the browser.

# Base URL of the Rudra backend API.
#  - Local dev:        http://localhost:8000   (also the built-in fallback)
#  - Vercel/Tunnel:    https://<your-tunnel>.trycloudflare.com  (set in Vercel env vars)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (Open Graph / metadata). Set on Vercel Production.
# NEXT_PUBLIC_APP_URL=https://rudra-kl5i.vercel.app
